{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "全能文件工作台",
  "version": "2.4.0",
  "identifier": "tw.opendesk.crossplatform",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run legal:bundle && npm run frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "全能文件工作台",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "copyright": "Copyright © 全能文件工作台貢獻者",
    "category": "Productivity",
    "shortDescription": "文字、試算表、簡報、PDF 與 MAGI 一站式本機工作台",
    "longDescription": "整合文字、試算表、簡報、內建 PDF 核心、文件備份、格式掃描、MAGI V2／V3 與安全熱修。",
    "externalBin": ["binaries/document-pdf-core"],
    "resources": ["resources/**/*"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist"
    },
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" },
      "nsis": { "installMode": "currentUser", "installerIcon": "icons/icon.ico" }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzNDc4MUM3RjFEMjNEREQKUldUZFBkTHh4NEZISTUzUFZva25PTU9CVHFnMU9QamlLTEdBNll4dzU5U1E2Mzg3dnJWaXppRjEK",
      "endpoints": ["https://github.com/WhaleChao/OpenDeskTW/releases/latest/download/latest.json"],
      "windows": { "installMode": "passive" }
    }
  }
}
