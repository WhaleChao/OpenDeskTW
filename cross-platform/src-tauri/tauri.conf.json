{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenDesk TW",
  "version": "2.2.1",
  "identifier": "tw.opendesk.crossplatform",
  "build": {
    "beforeDevCommand": "npm run frontend:dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run frontend:build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "OpenDesk TW",
        "width": 1180,
        "height": 820,
        "minWidth": 900,
        "minHeight": 680,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://github.com https://objects.githubusercontent.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "copyright": "Copyright © OpenDesk TW Contributors",
    "category": "Productivity",
    "shortDescription": "全繁體中文、Office 格式優先的本機文件工作台",
    "longDescription": "整合 ONLYOFFICE、LibreOffice、文件備份、PDF、相容性掃描、MAGI 與安全熱修。",
    "resources": ["resources/**/*"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.icns", "icons/icon.ico"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": "-"
    },
    "windows": {
      "webviewInstallMode": { "type": "embedBootstrapper" },
      "nsis": { "installMode": "currentUser", "installerIcon": "icons/icon.ico" }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDIzNDc4MUM3RjFEMjNEREQKUldUZFBkTHh4NEZISTUzUFZva25PTU9CVHFnMU9QamlLTEdBNll4dzU5U1E2Mzg3dnJWaXppRjEK",
      "endpoints": ["https://github.com/WhaleChao/OpenDeskTW/releases/latest/download/latest.json"],
      "windows": { "installMode": "passive" }
    }
  }
}
