{
  "name": "complete-document-workbench",
  "private": true,
  "version": "2.6.2",
  "license": "AGPL-3.0-or-later",
  "type": "module",
  "scripts": {
    "tauri": "tauri",
    "frontend:dev": "vite --host 127.0.0.1 --port 1420",
    "frontend:build": "vite build",
    "translations:generate": "node scripts/generate_onlyoffice_zh_tw_overrides.mjs",
    "legal:bundle": "node scripts/generate_third_party_licenses.mjs",
    "legal:source": "npm run legal:bundle && node scripts/generate_corresponding_source_bundle.mjs",
    "pdf-core:build": "node scripts/build_embedded_pdf_core.mjs",
    "test:pdf-core": "node scripts/run_pdf_core_test.mjs",
    "test:sidecar": "node scripts/test_pdf_sidecar.mjs",
    "test:traditional": "node ../scripts/test_onlyoffice_tw_plugin.mjs",
    "test:contracts": "node scripts/test_pdf_integration_contract.mjs",
    "test:legal": "npm run legal:bundle && node scripts/test_agpl_compliance.mjs",
    "test": "npm run test:traditional && npm run test:contracts && npm run test:pdf-core && npm run test:legal && cargo test --manifest-path src-tauri/Cargo.toml --lib",
    "dev": "tauri dev",
    "build": "npm run pdf-core:build && tauri build",
    "check": "cargo check --manifest-path src-tauri/Cargo.toml"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.8.0",
    "@tauri-apps/plugin-dialog": "^2.4.0",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.9.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.8.0",
    "opencc-js": "^1.4.1",
    "vite": "^7.0.0"
  }
}
